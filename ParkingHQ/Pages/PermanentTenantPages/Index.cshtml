@page
@model ParkingHQ.Web.Pages.PermanentTenantPages.IndexModel
@{
}

<div class="container p-3">
    <div class="row pt-4">
        <div class="col-6">
            <h2 class="text-primary">Tenants</h2>
        </div>
        <div class="col-6 text-end">
            <a asp-page="create" class="btn btn-primary float-right"><i class="bi bi-plus-square"></i> &nbsp; Create New Tenant</a>
        </div>
    </div>
    <br /> <br />

    <table class="table table-bordered table-striped" style="width:100%">
        <thead>
            <tr>
                <th>
                    First Name
                </th>
                <th>
                    Last Name
                </th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var obj in Model.PermanentTenants)
            {
                    <tr>
                        <td width="30%">
                            @obj.FirstName
                        </td>
                         <td width="30%">
                            @obj.LastName
                        </td>
                        <td>
                            <div class="w-75 btnbtn-group" role="group">
                                <a asp-page="Edit" asp-route-id="@obj.Id" class="btn btn-primary mx-2"><i class="bi bi-pencil-square"></i></a>
                                <a asp-page="Delete" asp-route-id="@obj.Id" class="btn btn-danger mx-2"><i class="bi bi-trash-fill"></i></a>
                                <a asp-page="CarParkSelect" asp-route-id="@obj.Id" class="btn btn-secondary mx-2"><i class="bi bi-building-gear" data-toggle="tooltip" data-placement="top" title="Manage parking lots"></i></a>
                            </div>
                        </td>
                    </tr>
            }
        </tbody>
    </table>
</div>