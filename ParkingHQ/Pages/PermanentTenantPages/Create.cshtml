@page
@model ParkingHQ.Web.Pages.PermanentTenantPages.CreateModel
@{
}
<h4>Create new Permanent Tenant</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="PermanentTenant.FirstName" class="control-label"></label>
                <input asp-for="PermanentTenant.FirstName" class="form-control" />
                <span asp-validation-for="PermanentTenant.FirstName" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="PermanentTenant.LastName" class="control-label"></label>
                <input asp-for="PermanentTenant.LastName" class="form-control" />
                <span asp-validation-for="PermanentTenant.LastName" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="PermanentTenant.Street" class="control-label"></label>
                <input asp-for="PermanentTenant.Street" class="form-control" />
                <span asp-validation-for="PermanentTenant.Street" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="PermanentTenant.City" class="control-label"></label>
                <input asp-for="PermanentTenant.City" class="form-control" />
                <span asp-validation-for="PermanentTenant.City" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="PermanentTenant.ZipCode" class="control-label"></label>
                <input asp-for="PermanentTenant.ZipCode" class="form-control" />
                <span asp-validation-for="PermanentTenant.ZipCode" class="text-danger"></span>
            </div>
            <div class="form-group mt-3">
                <input type="submit" value="Create" class="btn btn-primary" />
                <a asp-page="Index" class="btn btn-secondary" style="width:150px">Back to List</a>
            </div>
        </form>
    </div>
</div>

