@page
@model ParkingHQ.Web.Pages.CarParks.Tariff.CreateHolidayTariffModel

@{
    ViewData["Title"] = "Create";
}

<h1>Tariffs</h1>

<h4>Manage Holiday Tariff sections</h4>
<hr />


<table class="table table-bordered table-striped" style="width:100%">
    <thead>
        <tr>
            <th>
                End Time
            </th>
            <th>
                Price
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @if (Model.sections != null)
        {
            @foreach (var obj in Model.sections)
            {
                <tr>
                    <td width="40%">
                        @obj.TariffEndTime.TimeOfDay
                    </td>
                    <td width="40%">
                        @obj.TariffPrice
                    </td>
                    <td>
                        <div class="w-75 btnbtn-group" role="group">
                            <form asp-page-handler="view" method="post">
                                <input type="hidden" name="id" value="@obj.Id"/>
                                <input type="hidden" name="CarparkId" value="@Model.currentCarPark.Id" />
                                @*<a asp-page="Delete" asp-route-id="@obj.Id" class="btn btn-danger mx-2"></a>*@
                                    <button class="btn btn-danger"><i class="bi bi-trash-fill"></i> Delete</button>
                                    </form>
                                </div>
                    </td>
                </tr>
            }
        }
    </tbody>
</table>
<hr />
<h4>Add a new tariff section</h4>

<div class="row">
    <div class="col-md-4">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="TariffSectionHoliday.TariffEndTime" class="control-label"></label>
                <input asp-for="TariffSectionHolidayOnlyTime" class="form-control" />
                <span asp-validation-for="TariffSectionHoliday.TariffEndTime" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="TariffSectionHoliday.TariffPrice" class="control-label"></label>
                <input asp-for="TariffSectionHoliday.TariffPrice" class="form-control" />
                <span asp-validation-for="TariffSectionHoliday.TariffPrice" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Add" class="btn btn-primary mt-1" />
                <a asp-page="../Index" class="btn btn-secondary" style="width:150px">Back to List</a>
            </div>
        </form>
    </div>
</div>


@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
