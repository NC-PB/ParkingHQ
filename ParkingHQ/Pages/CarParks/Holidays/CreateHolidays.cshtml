@page
@model ParkingHQ.Web.Pages.CarParks.Holidays.CreateHolidaysModel

@{
    ViewData["Title"] = "CreateHolidays";
}

<h1>Holidays</h1>

<hr />
<table class="table table-bordered table-striped" style="width:100%">
    <thead>
        <tr>
            <th>
                Date
            </th>
            <th>
                Name
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @if (Model.Holidays != null)
        {
            @foreach (var obj in Model.Holidays)
            {
                <tr>
                    <td width="40%">
                        @obj.HolidayDate
                    </td>
                    <td width="40%">
                        @obj.HolidayName
                    </td>
                    <td>
                        <div class="w-75 btnbtn-group" role="group">
                            <form asp-page-handler="view" method="post">
                                <input type="hidden" name="id" value="@obj.Id" />
                                <input type="hidden" name="CarparkId" value="@Model.currentCarPark.Id" />
                                @*<a asp-page="Delete" asp-route-id="@obj.Id" class="btn btn-danger mx-2"></a>*@
                                <button class="btn btn-danger"><i class="bi bi-trash-fill"></i> Delete</button>
                            </form>
                        </div>
                    </td>
                </tr>
            }
        }
    </tbody>
</table>






<hr/>
<h4>Add a new Holiday Date</h4>
<div class="row">
    <div class="col-md-4">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="NewHoliday.HolidayName" class="control-label"></label>
                <input asp-for="NewHoliday.HolidayName" class="form-control" />
                <span asp-validation-for="NewHoliday.HolidayName" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="NewHoliday.HolidayDate" class="control-label"></label>
                <input asp-for="HolidayDateOnly" class="form-control" />
                <span asp-validation-for="HolidayDateOnly" class="text-danger"></span>
            </div>
            <div class="form-group mt-3">
                <input type="submit" value="Create" class="btn btn-primary" />
                <a asp-page="../Index" class="btn btn-secondary" style="width:150px">Back to List</a>
            </div>
        </form>
    </div>
</div>


@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
