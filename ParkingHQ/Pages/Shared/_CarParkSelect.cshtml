@using ParkingHQ.Models
@Model List<CarPark>

@foreach (CarPark obj in Model)
{
    <tr>
        <td width="50%">
            @obj.Name
        </td>
        <td>
            <div class="w-75 btnbtn-group" role="group">
                <a asp-page="Edit" asp-route-id="@obj.Id" class="btn btn-primary mx-2"><i class="bi bi-pencil-square"></i></a>
                <a asp-page="Delete" asp-route-id="@obj.Id" class="btn btn-danger mx-2"><i class="bi bi-trash-fill"></i></a>
                <a asp-page="Floors/Index" asp-route-id="@obj.Id" class="btn btn-secondary mx-2"><i class="bi bi-building-gear" data-toggle="tooltip" data-placement="top" title="Manage floors"></i></a>
            </div>
        </td>
    </tr>
}